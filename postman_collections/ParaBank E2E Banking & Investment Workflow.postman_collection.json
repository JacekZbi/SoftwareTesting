      "name": "Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const xml2js = require('xml2js');\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 200ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains user data\", function () {\r",
              "    const responseJson = xml2js.parseString(pm.response.text(), function (err, result) {\r",
              "        \r",
              "        \r",
              "      const customer = result.customer;\r",
              "        \r",
              "    \r",
              "        pm.expect(customer).to.have.property('id');\r",
              "        pm.expect(customer).to.have.property('firstName');\r",
              "        pm.expect(customer).to.have.property('lastName');\r",
              "\r",
              "    \r",
              "        const customerId = customer.id[0]; \r",
              "        pm.expect(customerId).to.not.be.undefined;\r",
              "        \r",
              "        pm.environment.set(\"customerId\", customerId);\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
