    {
      "name": "Get Account information",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const xml2js = require('xml2js');\r",
              "pm.test(\"Response time is less than 200ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(200);\r",
              "});\r",
              "pm.test(\"Account with the highest balance\", function () {\r",
              "    xml2js.parseString(pm.response.text(), function (err, result) {\r",
              "        pm.expect(err).to.be.null;\r",
              "\r",
              "        const accountsList = result.accounts.account;\r",
              "        \r",
              "\r",
              "        const firstAccount = accountsList[0];\r",
              "        const firstAccountId = firstAccount.id[0];\r",
              "        pm.environment.set(\"firstAccountId\", firstAccountId);\r",
              "        console.log(\"First Account ID:\", firstAccountId);\r",
              "\r",
              "\r",
              "      \r",
              "        let highestBalance = -100000000000;\r",
              "        let highestBalanceAccountId = null;\r",
              "\r",
              "        accountsList.forEach(function(account) {\r",
              "            const currentBalance = parseFloat(account.balance[0]);\r",
              "            const currentAccountId = account.id[0];\r",
              "\r",
              "            if (currentBalance > highestBalance) {\r",
              "                highestBalance = currentBalance;\r",
              "                highestBalanceAccountId = currentAccountId;\r",
              "            }\r",
              "        });\r",
              "\r",
              "        console.log(`Highest Balance found: $${highestBalance} in Account ID: ${highestBalanceAccountId}`);\r",
              "        pm.expect(highestBalanceAccountId).to.not.be.null;\r",
              "\r",
              "     \r",
              "        pm.environment.set(\"highestBalanceAccountId\", highestBalanceAccountId);\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
