    {
      "name": "Get positions",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const xml2js = require('xml2js');\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"Response time is less than 200ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(200);\r",
              "});\r",
              "pm.test(\"Retrieve tickers and set environment variable\", function () {\r",
              "    xml2js.parseString(pm.response.text(), function (err, result) {\r",
              "\r",
              "    \r",
              "        const positions = result.positions.position;\r",
              "        pm.expect(positions).to.be.an('array').and.not.be.empty;\r",
              "\r",
              "    \r",
              "        const ticker = positions[0].symbol[0];\r",
              "        const price = positions[0].purchasePrice[0];\r",
              "        const Name = positions[0].name[0];\r",
              "        pm.expect(ticker).to.be.a('string').and.not.be.empty;\r",
              "        pm.environment.set(\"tickerName\", Name);\r",
              "\r",
              "        pm.environment.set(\"tickerPrice\", price);\r",
              "        pm.environment.set(\"ticker\", ticker);\r",
              "        console.log(\"Ticker saved successfully:\", ticker, price);\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
